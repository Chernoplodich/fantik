# ======================================================================
# Fantik — пример переменных окружения.
# Скопируйте в .env и заполните реальными значениями:
#   cp .env.example .env
# Файл .env закоммичен в .gitignore — секреты никогда не попадут в репо.
# ======================================================================

# ---------- Application ----------
APP_ENV=dev                          # dev | staging | prod
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_RENDERER=console                 # console | json  (json в проде)
RELEASE=                             # заполняется CI (git sha)

# ---------- Telegram ----------
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
ADMIN_TG_IDS=111,222                 # csv tg_id первых админов (засеиваются)
BOT_RUN_MODE=polling                 # polling | webhook

# webhook (актуально только при BOT_RUN_MODE=webhook)
WEBHOOK_BASE_URL=                    # https://bot.example.com
WEBHOOK_PATH=/webhook                # без слэша в конце; к нему добавится sha256(token)
WEBHOOK_SECRET=                      # X-Telegram-Bot-Api-Secret-Token; 1-256 символов [A-Za-z0-9_-]
WEBHOOK_HOST=0.0.0.0                 # bind address внутри контейнера
WEBHOOK_PORT=8080

# Health/metrics
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
METRICS_PORT=8081

# ---------- PostgreSQL ----------
POSTGRES_USER=fantik
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fantik
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Полный DSN собирается в config.py, но можно переопределить целиком:
# POSTGRES_DSN=postgresql+asyncpg://fantik:changeme@postgres:5432/fantik
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800
POSTGRES_ECHO=false

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
REDIS_FSM_DB=1                       # отдельная БД для FSM aiogram
REDIS_TASKIQ_DB=2                    # брокер задач
REDIS_CACHE_DB=0                     # кэш ролей/страниц/etc

# ---------- Meilisearch ----------
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=changeme-replace-with-32-chars-or-more
SEARCH_BACKEND=meili                 # meili | pg

# ---------- TaskIQ ----------
TASKIQ_QUEUE_DEFAULT=fantik:tasks
TASKIQ_QUEUE_BROADCAST=fantik:broadcast

# ---------- Broadcast ----------
BROADCAST_RATE=25                    # msg/s — буфер до лимита Telegram 30
BROADCAST_RATE_CAPACITY=25
ALLOW_PAID_BROADCAST=false           # true → использовать allow_paid_broadcast в copy_message (1000 msg/s)

# ---------- Time ----------
DEFAULT_TIMEZONE=Europe/Moscow

# ---------- Sentry (опционально) ----------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.01

# ---------- Feature limits ----------
MAX_CHAPTERS_PER_FIC=200
MAX_CHAPTER_CHARS=100000
MAX_FICS_PER_DAY=3
MAX_REPORTS_PER_DAY=20
MAX_USER_UPDATES_PER_MIN=30
PAGE_LIMIT_UTF16=3900

# ---------- Docker deploy (prod only) ----------
VERSION=latest                       # тег образа для docker-compose.prod.yml
REGISTRY=registry.example.com
