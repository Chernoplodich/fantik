{
  "uid": "fantik-bot-health",
  "title": "Fantik — Bot Health",
  "tags": ["fantik", "bot"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Updates RPS (by type)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(bot_updates_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Handler latency p50/p95/p99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "P50",
          "expr": "histogram_quantile(0.5, sum(rate(bot_handler_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum(rate(bot_handler_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "P99",
          "expr": "histogram_quantile(0.99, sum(rate(bot_handler_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(bot_handler_errors_total[5m])) / clamp_min(sum(rate(bot_updates_total[5m])), 1)",
          "legendFormat": "errors/updates"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rate-limit hits",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (scope) (rate(bot_rate_limit_hits_total[5m]))",
          "legendFormat": "{{scope}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    }
  ]
}
