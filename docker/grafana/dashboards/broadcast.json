{
  "uid": "fantik-broadcast",
  "title": "Fantik — Broadcast",
  "tags": ["fantik", "broadcast"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Deliveries per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(broadcast_deliveries_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Token bucket wait p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(broadcast_bucket_wait_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Blocked ratio",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(broadcast_deliveries_total{status=\"blocked\"}[5m])) / clamp_min(sum(rate(broadcast_deliveries_total[5m])), 1)",
          "legendFormat": "blocked/total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    }
  ]
}
