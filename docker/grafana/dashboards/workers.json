{
  "uid": "fantik-workers",
  "title": "Fantik — Workers",
  "tags": ["fantik", "worker"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (queue) (worker_queue_depth)",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Task duration p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(worker_task_duration_seconds_bucket[5m])) by (le, task))",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Retries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (task) (rate(worker_task_retries_total[5m]))",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failures (task errors)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (task) (rate(worker_task_duration_seconds_count{result=\"error\"}[5m]))",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Outbox oldest pending (s)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "fantik-prometheus" },
      "targets": [{ "refId": "A", "expr": "outbox_oldest_pending_age_seconds" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
